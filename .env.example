# HealthGuard AI environment template
# Copy this file to .env for local development. Never commit a real .env file.
# All values below are placeholders or local-development defaults. Replace secrets in each environment.

# -----------------------------------------------------------------------------
# Application identity and runtime mode
# -----------------------------------------------------------------------------
# Human-readable application name used in logs, docs, and UI copy.
APP_NAME="HealthGuard AI"

# Preferred public environment label for deployment platforms.
APP_ENV=development

# Backend canonical environment value. Must be one of: development, test, staging, production.
ENVIRONMENT=development

# Enable verbose framework/debug behavior only in local development.
DEBUG=false

# Backend log level. Use INFO in production unless actively investigating an incident.
LOG_LEVEL=INFO

# Enable FastAPI Swagger/ReDoc docs. Must be false in production.
DOCS_ENABLED=true

# API prefix mounted by the backend router.
API_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# Frontend and CORS
# -----------------------------------------------------------------------------
# Public frontend origin used by backend links, emails, CORS, and CSRF origin checks.
FRONTEND_URL=http://localhost:3000
WEB_APP_URL=http://localhost:3000

# Browser-visible API URL. Never place secrets in NEXT_PUBLIC_* variables.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Exact allowed browser origins. Do not use wildcard CORS with credentials.
CORS_ORIGINS=["http://localhost:3000"]

# -----------------------------------------------------------------------------
# Database and Redis
# -----------------------------------------------------------------------------
# Canonical backend database URL. This project currently installs asyncpg.
DATABASE_URL=postgresql+asyncpg://healthguard:healthguard@postgres:5432/healthguard

# Alternative managed-provider form if psycopg is installed and tested:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/healthguard

# Redis URL for cache, rate limits, jobs, locks, and short-lived tokens.
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Authentication, sessions, and cookies
# -----------------------------------------------------------------------------
# Canonical backend signing secret. Generate at least 32 random bytes for every env.
TOKEN_SECRET=replace-with-at-least-32-random-characters

# Alias used by some deployment templates. Keep equal to TOKEN_SECRET if consumed.
JWT_SECRET_KEY=replace-with-at-least-32-random-characters

# JWT signing algorithm. Keep HS256 unless the token code is changed and reviewed.
JWT_ALGORITHM=HS256

# Access-token lifetime in minutes.
ACCESS_TOKEN_MINUTES=15
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh-token lifetime in days.
REFRESH_TOKEN_DAYS=7
REFRESH_TOKEN_EXPIRE_DAYS=7

# Secure cookies must be true in staging/production behind HTTPS.
COOKIE_SECURE=false

# Optional cookie domain, for example .example.com. Leave empty locally.
COOKIE_DOMAIN=

# Optional Google OAuth-ready architecture. Configure only when OAuth is enabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# LLM, embeddings, and RAG
# -----------------------------------------------------------------------------
# LLM provider name used by backend orchestration. Keep empty/offline if no provider is configured.
LLM_PROVIDER=openai

# Provider API key. Never commit a real key.
OPENAI_API_KEY=

# Chat/completion model name approved for the deployment.
OPENAI_MODEL=

# Embedding model name approved for retrieval.
EMBEDDING_MODEL=

# Vector database provider. pgvector is the intended managed PostgreSQL extension option.
VECTOR_DATABASE_PROVIDER=pgvector

# Optional separate vector DB URL. Leave empty to use DATABASE_URL.
VECTOR_DATABASE_URL=

# -----------------------------------------------------------------------------
# Storage and medical-record uploads
# -----------------------------------------------------------------------------
# Storage provider. Use local-private for development or s3-compatible storage in production.
STORAGE_PROVIDER=local-private
STORAGE_BACKEND=local-private

# Local private storage root for development only. Do not serve this directory publicly.
RECORD_STORAGE_ROOT=.local/records

# S3-compatible private object storage configuration. Never use public buckets for records.
S3_ENDPOINT_URL=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Maximum upload size. Backend canonical value is bytes; FILE_MAX_SIZE_MB is a human alias.
FILE_MAX_SIZE_MB=10
RECORD_MAX_UPLOAD_BYTES=10485760

# Explicit allowed upload extensions. MIME and file signatures are also validated by the app.
RECORD_ALLOWED_EXTENSIONS=[".pdf",".png",".jpg",".jpeg",".txt"]

# Application-level encryption key placeholder for future field/file encryption integrations.
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Email and SMS notifications
# -----------------------------------------------------------------------------
# Email provider name, for example smtp, resend, ses. Empty disables provider-specific sending.
EMAIL_PROVIDER=

# From address for transactional emails.
EMAIL_FROM=no-reply@healthguard.ai
SMTP_FROM_EMAIL=no-reply@healthguard.ai

# SMTP settings. SMTP_PASSWORD requires SMTP_USERNAME.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# SMS provider settings. Leave empty unless SMS delivery is implemented and approved.
SMS_PROVIDER=
SMS_API_KEY=

# -----------------------------------------------------------------------------
# OCR and report processing
# -----------------------------------------------------------------------------
# OCR provider. local means local parser/OCR worker; provider values require worker configuration.
OCR_PROVIDER=local

# -----------------------------------------------------------------------------
# Emergency, privacy, and safety configuration
# -----------------------------------------------------------------------------
# India emergency number. 112 is the national emergency response number.
EMERGENCY_NUMBER=112
EMERGENCY_COUNTRY_HINT="India national emergency number: 112"

# Account deletion grace period in days. Set to 0 only after product/legal review.
ACCOUNT_DELETION_GRACE_DAYS=7

# Short-lived export link expiration in minutes.
EXPORT_DOWNLOAD_MINUTES=10

# Disclaimer shown across medical/AI features.
MEDICAL_DISCLAIMER="HealthGuard AI provides educational information only and does not replace professional medical advice, diagnosis, or treatment. In an emergency, contact local emergency services immediately."

# -----------------------------------------------------------------------------
# Observability and error monitoring
# -----------------------------------------------------------------------------
# Optional Sentry DSN or equivalent error monitoring hook. Never expose private DSNs in client bundles.
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Production reminders
# -----------------------------------------------------------------------------
# Never commit: real .env files, API keys, passwords, private keys, production database URLs,
# cloud credentials, user health data, uploaded medical reports, exports, or logs with PHI.
